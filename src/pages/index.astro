---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const categories = (await getCollection('categories')).slice(0, 6);
const featuredWorkshops = (await getCollection('workshops'))
  .filter((workshop) => workshop.data.featured)
  .slice(0, 3);
const galleryItems = (await getCollection('gallery'))
  .filter((item) => item.data.featured)
  .slice(0, 4);
const testimonials = (await getCollection('testimonials')).slice(0, 3);
---

<BaseLayout
  title='Cudoteka — twórcze warsztaty i animacje dla dzieci | Warszawa'
  description='Cudoteka to warsztaty rozwojowe i artystyczne, sensoplastyka, animacje i atrakcje dla dzieci i dorosłych. Warszawa i okolice.'
>
  <section class='section hero-section'>
    <div class='wrap hero-grid'>
      <div class='reveal-fade-up hero-copy'>
        <span class='eyebrow'>Pracownia twórcza • Animacje • Eventy</span>
        <h1>Miejsce, w którym dzieci tworzą <em>cuda</em></h1>
        <p>
          Cudoteka łączy warsztaty sensoryczne, plastyczne i edukacyjne z radością wspólnej zabawy.
          Tworzymy wyjątkowe atrakcje dla urodzin, przedszkoli, szkół i wydarzeń plenerowych.
        </p>
        <div class='hero-actions'>
          <a href='/kontakt/' class='btn btn-primary'>Zarezerwuj termin</a>
          <a href='/oferta/' class='btn btn-ghost'>Zobacz ofertę</a>
        </div>
        <ul class='hero-checks'>
          <li>✓ Bezpieczne materiały</li>
          <li>✓ Przyjeżdżamy do klienta</li>
          <li>✓ Program dopasowany do wieku</li>
        </ul>
      </div>

      <div class='reveal-fade-up hero-visual'>
        <div class='hero-shell'>
          <img src='/images/hero/hero.webp' alt='Dzieci bawiące się podczas warsztatów twórczych w Cudotece' width='720' height='560' loading='eager' decoding='async' />
        </div>
        <div class='mini-pill pill-one'>23 rodzaje warsztatów</div>
        <div class='mini-pill pill-two'>Urodziny • Festyny • Szkoły</div>
      </div>
    </div>
  </section>

  <section class='trust-bar' aria-label='Najważniejsze atuty Cudoteki'>
    <div class='wrap trust-grid'>
      <div class='trust-item'>
        <span class='trust-icon'>🛡️</span>
        <div>
          <strong>Bezpieczeństwo</strong>
          <span>sprawdzone materiały</span>
        </div>
      </div>
      <div class='trust-item'>
        <span class='trust-icon'>🎯</span>
        <div>
          <strong>Indywidualnie</strong>
          <span>dostosowane do wieku</span>
        </div>
      </div>
      <div class='trust-item'>
        <span class='trust-icon'>🚐</span>
        <div>
          <strong>Dojazd</strong>
          <span>Warszawa i okolice</span>
        </div>
      </div>
      <div class='trust-item'>
        <span class='trust-icon'>👨‍👩‍👧</span>
        <div>
          <strong>Dla każdego</strong>
          <span>dzieci i dorośli</span>
        </div>
      </div>
    </div>
  </section>

  <section class='section about-section'>
    <div class='wrap about-grid'>
      <div class='reveal-fade-up about-visual'>
        <div class='about-shell'>
          <img src='/images/about/about.webp' alt='Aleksandra Dąbrowska podczas warsztatów w Cudotece' width='640' height='560' loading='lazy' decoding='async' />
        </div>
        <div class='about-badge'>♥ z pasją do dzieci</div>
      </div>

      <div class='reveal-fade-up about-copy'>
        <span class='eyebrow'>O nas</span>
        <h2>Tworzymy przestrzeń, w której każde dziecko czuje się wyjątkowe</h2>
        <p>
          Cudoteka to nowa odsłona E-CUD — Centrum Edukacyjno-Eventowego. Z pasją tworzymy zajęcia,
          które łączą naukę, zmysły i wspólną radość tworzenia.
        </p>
        <p>
          Stawiamy na bezpieczeństwo i dobre emocje: używamy sprawdzonych materiałów, a każdy program
          dopasowujemy do wieku i charakteru uczestników.
        </p>
        <p class='sign'>Aleksandra Dąbrowska <small>założycielka Cudoteki</small></p>
        <a href='/o-nas/' class='btn btn-ghost'>Poznaj nas bliżej</a>
      </div>
    </div>
  </section>

  <section class='section offer-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Nasza oferta</span>
        <h2>Warsztaty i atrakcje na każdą okazję</h2>
        <p>Wybierz jedną kategorię lub zbuduj z nami pełen program wydarzenia.</p>
      </div>

      <div class='cat-grid'>
        {categories.map((cat) => (
          <a href={`/oferta/${cat.data.slug}/`} class={`cat-card cat-${cat.data.color}`}>
            <span class='cat-icon'>{cat.data.icon}</span>
            <h3>{cat.data.title}</h3>
            <p>{cat.data.description}</p>
            <span class='cat-link'>Zobacz warsztaty →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class='section featured-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Polecane warsztaty</span>
        <h2>Najbardziej lubiane zajęcia naszych uczestników</h2>
      </div>

      <div class='workshop-grid'>
        {featuredWorkshops.map((workshop) => (
          <div class='double-bezel-outer'>
            <a href={`/warsztaty/${workshop.data.slug}/`} class='workshop-card double-bezel-inner'>
              <div class='card-top'>
                <h3>{workshop.data.title}</h3>
                <p>{workshop.data.shortDescription}</p>
              </div>
              <div class='card-meta'>
                <span>👶 {workshop.data.ageRange}</span>
                <span>⏱️ {workshop.data.duration}</span>
              </div>
            </a>
          </div>
        ))}
      </div>

      <div class='section-cta'>
        <a href='/warsztaty/' class='btn btn-ghost'>Zobacz wszystkie warsztaty</a>
      </div>
    </div>
  </section>

  <section class='section gallery-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Galeria</span>
        <h2>Tak wygląda dobra zabawa</h2>
      </div>

      <div class='gallery-grid'>
        {galleryItems.map((item) => (
          <div class='gallery-item'>
            <img src={item.data.image} alt={item.data.alt} />
          </div>
        ))}
      </div>

      <div class='section-cta'>
        <a href='/galeria/' class='btn btn-ghost'>Zobacz więcej zdjęć</a>
      </div>
    </div>
  </section>

  <section class='section testimonials-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Opinie</span>
        <h2>Co mówią o nas rodzice i organizatorzy</h2>
      </div>

      <div class='testimonial-grid'>
        {testimonials.map((testimonial) => (
          <div class='double-bezel-outer'>
            <div class='testimonial-card double-bezel-inner'>
              <div class='stars'>{'⭐'.repeat(testimonial.data.rating)}</div>
              <p class='quote'>“{testimonial.data.content}”</p>
              <div class='author'>
                <strong>{testimonial.data.author}</strong>
                <span>{testimonial.data.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-section {
    padding-top: 120px;
    padding-bottom: 70px;
    background: linear-gradient(145deg, var(--cream) 0%, var(--cream-2) 100%);
  }

  .hero-grid {
    display: grid;
    gap: 40px;
    align-items: center;
  }

  .hero-copy h1 {
    font-size: clamp(2.4rem, 6vw, 4rem);
    margin: 18px 0 20px;
    max-width: 12ch;
  }

  .hero-copy h1 em {
    color: var(--blue-deep);
    font-style: italic;
  }

  .hero-copy p {
    color: var(--ink-soft);
    font-size: 1.08rem;
    max-width: 56ch;
    margin-bottom: 24px;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 20px;
  }

  .hero-checks {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    color: var(--ink);
    font-weight: 700;
    font-size: 0.95rem;
  }

  .hero-shell, .about-shell {
    padding: 8px;
    background: rgba(255, 255, 255, 0.7);
    border-radius: 2rem;
    box-shadow: var(--shadow);
  }

  .hero-shell img, .about-shell img {
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: calc(2rem - 8px);
    display: block;
  }

  .hero-visual {
    position: relative;
  }

  .mini-pill {
    position: absolute;
    background: #fff;
    padding: 10px 14px;
    border-radius: 999px;
    box-shadow: var(--shadow-sm);
    font-size: 0.84rem;
    font-weight: 800;
    color: var(--ink);
  }

  .pill-one {
    top: 14px;
    left: 10px;
  }

  .pill-two {
    bottom: 14px;
    right: 8px;
  }

  .trust-bar {
    background: var(--blue-deep);
    color: #fff;
    padding: 28px 0;
  }

  .trust-grid {
    display: grid;
    gap: 18px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
  }

  .trust-icon {
    font-size: 1.4rem;
  }

  .trust-item span {
    display: block;
    font-size: 0.82rem;
    opacity: 0.85;
    font-weight: 600;
  }

  .about-grid {
    display: grid;
    gap: 40px;
    align-items: center;
  }

  .about-copy h2 {
    font-size: clamp(1.8rem, 4.5vw, 2.7rem);
    margin: 16px 0 18px;
  }

  .about-copy p {
    color: var(--ink-soft);
    margin-bottom: 16px;
    font-size: 1rem;
  }

  .about-badge {
    position: absolute;
    bottom: -16px;
    right: 12px;
    background: var(--peach-tint);
    color: var(--peach);
    padding: 10px 14px;
    border-radius: 999px;
    font-weight: 800;
    box-shadow: var(--shadow-sm);
  }

  .sign {
    font-family: 'Fraunces', Georgia, serif;
    font-style: italic;
    color: var(--blue-deep);
    margin-top: 24px;
    margin-bottom: 20px;
  }

  .sign small {
    display: block;
    font-family: 'Nunito Sans', sans-serif;
    font-style: normal;
    font-size: 0.82rem;
    color: var(--ink-soft);
    font-weight: 700;
    margin-top: 4px;
  }

  .sec-head {
    text-align: center;
    max-width: 46rem;
    margin: 0 auto 40px;
  }

  .sec-head h2 {
    font-size: clamp(1.9rem, 4.3vw, 2.8rem);
    margin: 14px 0 12px;
  }

  .sec-head p {
    color: var(--ink-soft);
    font-size: 1.02rem;
  }

  .cat-grid, .workshop-grid, .testimonial-grid {
    display: grid;
    gap: 24px;
  }

  .cat-card, .workshop-card, .testimonial-card {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .cat-card {
    background: #fff;
    border-radius: 1.6rem;
    padding: 28px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cat-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }

  .cat-icon {
    font-size: 2rem;
    margin-bottom: 12px;
  }

  .cat-card h3 {
    font-size: 1.25rem;
    margin-bottom: 10px;
  }

  .cat-card p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    flex-grow: 1;
    margin-bottom: 16px;
  }

  .cat-link {
    font-weight: 800;
    color: var(--blue-deep);
  }

  .cat-blue { background: linear-gradient(135deg, #fff 0%, var(--blue-tint) 100%); }
  .cat-mint { background: linear-gradient(135deg, #fff 0%, var(--mint-tint) 100%); }
  .cat-peach { background: linear-gradient(135deg, #fff 0%, var(--peach-tint) 100%); }
  .cat-gold { background: linear-gradient(135deg, #fff 0%, #faf1dc 100%); }
  .cat-lilac { background: linear-gradient(135deg, #fff 0%, #efe7f6 100%); }

  .workshop-card {
    justify-content: space-between;
    gap: 20px;
  }

  .card-top h3 {
    font-size: 1.2rem;
    margin-bottom: 8px;
  }

  .card-top p, .quote {
    color: var(--ink-soft);
    line-height: 1.6;
    font-size: 0.96rem;
  }

  .card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--ink-soft);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding-top: 12px;
  }

  .gallery-grid {
    display: grid;
    gap: 20px;
  }

  .gallery-item img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: 1.4rem;
    display: block;
    box-shadow: var(--shadow-sm);
  }

  .testimonial-card {
    gap: 16px;
  }

  .stars {
    font-size: 0.95rem;
  }

  .author {
    display: flex;
    flex-direction: column;
    gap: 4px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    padding-top: 12px;
  }

  .author span {
    color: var(--ink-soft);
    font-size: 0.85rem;
  }

  .section-cta {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  @media (min-width: 680px) {
    .trust-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .cat-grid, .workshop-grid, .testimonial-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: 1.02fr 0.98fr;
      gap: 56px;
    }

    .about-grid {
      grid-template-columns: 0.95fr 1.05fr;
      gap: 56px;
    }

    .trust-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .cat-grid, .workshop-grid, .testimonial-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .gallery-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
