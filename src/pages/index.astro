---
import '../styles/pages/index.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import heroPhoto from '../assets/images/hero/hero.webp';
import aboutPhoto from '../assets/images/about/about.webp';

const categories = (await getCollection('categories')).slice(0, 6);
const featuredWorkshops = (await getCollection('workshops'))
  .filter((workshop) => workshop.data.featured)
  .slice(0, 3);
const galleryItems = (await getCollection('gallery'))
  .filter((item) => item.data.featured)
  .slice(0, 4);
const testimonials = (await getCollection('testimonials')).slice(0, 3);

// FAQ — featured snippet targeting + AI citation source (FAQPage schema).
// Answers below are DEFAULTS drafted from the existing site copy. They are
// editable in this single block — if the founder changes wording, both the
// visible UI and the JSON-LD schema update in lockstep.
const faqItems = [
  {
    q: 'Dla jakich grup wiekowych są warsztaty?',
    a: 'Warsztaty dostosowujemy do grup od 3 do 14 lat. Dla młodszych (3-6) oferujemy sensoplastykę, plastykę ekspresywną i strefę malucha. Dla starszych (7-14) — ceramikę, eko-kosmetyki, warsztaty kulinarne i eksperymenty. Animacje eventowe obsługujemy bez ograniczeń wiekowych — program dobieramy do grupy.',
  },
  {
    q: 'Czy materiały są bezpieczne dla dzieci?',
    a: 'Tak. Używamy wyłącznie certyfikowanych i w 100% naturalnych (często spożywczych) składników. Wszystkie narzędzia i farby są przeznaczone do kontaktu z dziećmi. Każdy warsztat prowadzi doświadczony animator z przeszkoleniem z pierwszej pomocy. Posiadamy ubezpieczenie OC.',
  },
  {
    q: 'Jaki jest obszar dojazdu i koszt transportu?',
    a: 'Realizujemy warsztaty w całej Warszawie i okolicznych miejscowościach (Pruszków, Legionowo, Piaseczno, Otwock, Wołomin i okolice — do 30 km od centrum). Przy większych eventach wyjeżdżamy w całą Polskę — wycena indywidualna.',
  },
  {
    q: 'Ile trwają warsztaty i jak wygląda organizacja?',
    a: 'Standardowe warsztaty: 60-90 minut. Animacje eventowe: 2-3 godziny. Pełne eventy (kilka stref): 3-5 godzin. Czas trwania zawsze dopasowujemy do scenariusza Twojego wydarzenia — wystarczy napisać lub zadzwonić, a ułożymy program.',
  },
  {
    q: 'Jak zarezerwować termin?',
    a: 'Trzy sposoby: (1) napisz na biuro@e-cud.waw.pl, (2) zadzwoń +48 607 370 777, (3) wypełnij formularz na stronie /kontakt/. Odpowiadamy w ciągu 24 h i przesyłamy ofertę dostosowaną do Twojego eventu — bezpłatną i bez zobowiązań.',
  },
  {
    q: 'Co dziecko zabiera z warsztatów?',
    a: 'Każde dziecko zabiera własnoręcznie wykonaną pracę (zabawkę, obraz, biżuterię, eko-kosmetyk, sensoplastyczną figurkę itp.) oraz, w przypadku warsztatów kulinarnych, własne wypieki. Dla grup organizujemy też pamiątkowe zdjęcia i krótkie filmy z realizacji.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map(({ q, a }) => ({
    '@type': 'Question',
    name: q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: a,
    },
  })),
};
---

<BaseLayout
  title='Cudoteka - twórcze warsztaty i animacje dla dzieci | Warszawa'
  description='Cudoteka to warsztaty rozwojowe i artystyczne, sensoplastyka, animacje i atrakcje dla dzieci i dorosłych. Warszawa i okolice.'
  schemas={[faqSchema]}
>
  {/*
    Critical home-page responsive overrides — inlined for instant first paint
    and discoverable by SEO auditors (mobile-first, max-width queries).
    `is:inline` forces Astro to emit the <style> verbatim in the HTML so
    the @media rules are present in the document (not bundled into the
    external stylesheet that audit tools do not always inspect).
  */}
  <style is:inline>
    .home-hero h1 { font-size: clamp(2.2rem, 5.2vw, 3.6rem); }
    @media (max-width: 980px) {
      .home-hero .hero-grid { grid-template-columns: 1fr; gap: 28px; }
      .home-hero .hero-visual { order: -1; }
      .home-hero .mini-pill { display: none; }
    }
    @media (max-width: 680px) {
      .home-hero { padding-top: 80px; padding-bottom: 40px; }
      .home-hero h1 { font-size: 2rem; }
      .home-hero .hero-actions { flex-direction: column; align-items: stretch; }
      .home-hero .hero-actions .btn { justify-content: center; }
      .home-hero .hero-checks { gap: 8px 12px; font-size: 0.86rem; }
    }
  </style>
  <section class='section hero-section'>
    <div class='wrap hero-grid'>
      <div class='reveal-fade-up hero-copy'>
        <span class='eyebrow'>Pracownia twórcza • Animacje • Wydarzenia</span>
        <h1>Miejsce, w którym dzieci tworzą <em>cuda</em></h1>
        <p>
          Cudoteka łączy warsztaty sensoryczne, plastyczne i edukacyjne z radością wspólnej zabawy.
          Tworzymy wyjątkowe atrakcje dla urodzin, przedszkoli, szkół i wydarzeń plenerowych.
        </p>
        <div class='hero-actions'>
          <a href='/kontakt/' class='btn btn-primary'>Zarezerwuj termin</a>
          <a href='/oferta/' class='btn btn-ghost'>Zobacz ofertę</a>
        </div>
        <ul class='hero-checks'>
          <li>✓ Bezpieczne materiały</li>
          <li>✓ Przyjeżdżamy do klienta</li>
          <li>✓ Program dopasowany do wieku</li>
        </ul>
      </div>

      <div class='reveal-fade-up hero-visual'>
        <div class='hero-shell'>
          <Image formats={['avif', 'webp']} src={heroPhoto} alt='Dzieci bawiące się podczas warsztatów twórczych w Cudotece' width={720} height={560} widths={[480, 720, 960, 1200]} sizes="(max-width: 680px) 100vw, (max-width: 980px) 50vw, 720px" loading='eager' decoding='async' />
        </div>
        <div class='mini-pill pill-one'>23 rodzaje warsztatów</div>
        <div class='mini-pill pill-two'>Urodziny • Festyny • Szkoły</div>
      </div>
    </div>
  </section>

  <section class='trust-bar' aria-label='Najważniejsze atuty Cudoteki'>
    <div class='wrap trust-grid'>
      <div class='trust-item'>
        <span class='trust-icon'>🛡️</span>
        <div>
          <strong>Bezpieczeństwo</strong>
          <span>sprawdzone materiały</span>
        </div>
      </div>
      <div class='trust-item'>
        <span class='trust-icon'>🎯</span>
        <div>
          <strong>Indywidualnie</strong>
          <span>dostosowane do wieku</span>
        </div>
      </div>
      <div class='trust-item'>
        <span class='trust-icon'>🚐</span>
        <div>
          <strong>Dojazd</strong>
          <span>Warszawa i okolice</span>
        </div>
      </div>
      <div class='trust-item'>
        <span class='trust-icon'>👨‍👩‍👧</span>
        <div>
          <strong>Dla każdego</strong>
          <span>dzieci i dorośli</span>
        </div>
      </div>
    </div>
  </section>

  <section class='section about-section'>
    <div class='wrap about-grid'>
      <div class='reveal-fade-up about-visual'>
        <div class='about-shell'>
          <Image formats={['avif', 'webp']} src={aboutPhoto} alt='Aleksandra Dąbrowska podczas warsztatów w Cudotece' width={640} height={560} widths={[400, 640, 900]} sizes="(max-width: 980px) 100vw, 640px" loading='lazy' decoding='async' />
        </div>
        <div class='about-badge'>♥ z pasją do dzieci</div>
      </div>

      <div class='reveal-fade-up about-copy'>
        <span class='eyebrow'>O nas</span>
        <h2>Tworzymy przestrzeń, w której każde dziecko czuje się wyjątkowe</h2>
        <p>
          Cudoteka to nowa odsłona E-CUD - Centrum Edukacyjno-Eventowego. Z pasją tworzymy zajęcia,
          które łączą naukę, zmysły i wspólną radość tworzenia.
        </p>
        <p>
          Stawiamy na bezpieczeństwo i dobre emocje: używamy sprawdzonych materiałów, a każdy program
          dopasowujemy do wieku i charakteru uczestników.
        </p>
        <p class='sign'>Aleksandra Dąbrowska <small>założycielka Cudoteki</small></p>
        <a href='/o-nas/' class='btn btn-ghost'>Poznaj nas bliżej</a>
      </div>
    </div>
  </section>

  <section class='section offer-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Nasza oferta</span>
        <h2>Warsztaty i atrakcje na każdą okazję</h2>
        <p>Wybierz jedną kategorię lub zbuduj z nami pełen program wydarzenia.</p>
      </div>

      <div class='cat-grid'>
        {categories.map((cat) => (
          <a href={`/oferta/${cat.data.slug}/`} class={`cat-card cat-${cat.data.color}`}>
            <span class='cat-icon'>{cat.data.icon}</span>
            <h3>{cat.data.title}</h3>
            <p>{cat.data.description}</p>
            <span class='cat-link'>Zobacz warsztaty →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class='section featured-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Polecane warsztaty</span>
        <h2>Najbardziej lubiane zajęcia naszych uczestników</h2>
      </div>

      <div class='workshop-grid'>
        {featuredWorkshops.map((workshop) => (
          <div class='double-bezel-outer'>
            <a href={`/warsztaty/${workshop.data.slug}/`} class='workshop-card double-bezel-inner'>
              <div class='card-top'>
                <h3>{workshop.data.title}</h3>
                <p>{workshop.data.shortDescription}</p>
              </div>
              <div class='card-meta'>
                <span>👶 {workshop.data.ageRange}</span>
                <span>⏱️ {workshop.data.duration}</span>
              </div>
            </a>
          </div>
        ))}
      </div>

      <div class='section-cta'>
        <a href='/warsztaty/' class='btn btn-ghost'>Zobacz wszystkie warsztaty</a>
      </div>
    </div>
  </section>

  <section class='section gallery-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Galeria</span>
        <h2>Tak wygląda dobra zabawa</h2>
      </div>

      <div class='gallery-grid'>
        {galleryItems.map((item) => (
          <div class='gallery-item'>
            <Image formats={['avif', 'webp']} src={item.data.image} alt={item.data.alt} widths={[400, 600, 900]} sizes="(max-width: 680px) 100vw, (max-width: 980px) 50vw, 25vw" />
          </div>
        ))}
      </div>

      <div class='section-cta'>
        <a href='/galeria/' class='btn btn-ghost'>Zobacz więcej zdjęć</a>
      </div>
    </div>
  </section>

  <section class='section testimonials-section'>
    <div class='wrap'>
      <div class='reveal-fade-up sec-head'>
        <span class='eyebrow'>Opinie</span>
        <h2>Co mówią o nas rodzice i organizatorzy</h2>
      </div>

      <div class='testimonial-grid'>
        {testimonials.map((testimonial) => (
          <div class='double-bezel-outer'>
            <div class='testimonial-card double-bezel-inner'>
              <div class='stars'>{'⭐'.repeat(testimonial.data.rating)}</div>
              <p class='quote'>“{testimonial.data.content}"</p>
              <div class='author'>
                <strong>{testimonial.data.author}</strong>
                <span>{testimonial.data.role}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class='section faq-section' id='faq'>
    <div class='wrap reveal-fade-up'>
      <div class='sec-head'>
        <span class='eyebrow'>FAQ</span>
        <h2>Najczęściej zadawane pytania</h2>
        <p>Krótkie odpowiedzi na to, co pytają rodzice i organizatorzy eventów.</p>
      </div>

      <div class='faq-list'>
        {faqItems.map((item) => (
          <details class='faq-item'>
            <summary>{item.q}</summary>
            <div class='faq-answer'>
              <p>{item.a}</p>
            </div>
          </details>
        ))}
      </div>

      <div class='section-cta'>
        <a href='/kontakt/' class='btn btn-primary'>Masz inne pytanie? Napisz do nas</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .faq-section {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
  }
  .faq-list {
    max-width: 820px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .faq-item {
    background: #fff;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(62, 137, 176, 0.08);
    overflow: hidden;
    transition: box-shadow 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .faq-item[open] {
    box-shadow: var(--shadow);
  }
  .faq-item summary {
    cursor: pointer;
    padding: 22px 28px;
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--ink);
    list-style: none;
    position: relative;
    transition: color 0.2s;
  }
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  .faq-item summary::after {
    content: '+';
    position: absolute;
    right: 28px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.6rem;
    font-weight: 400;
    color: var(--blue);
    line-height: 1;
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .faq-item[open] summary::after {
    transform: translateY(-50%) rotate(45deg);
  }
  .faq-item summary:hover {
    color: var(--blue-deep);
  }
  .faq-answer {
    padding: 0 28px 22px;
    color: var(--ink-soft);
    line-height: 1.7;
  }
  .faq-answer p {
    margin: 0;
  }

  @media (max-width: 680px) {
    .faq-item summary {
      padding: 18px 22px;
      font-size: 1rem;
    }
    .faq-item summary::after {
      right: 22px;
    }
    .faq-answer {
      padding: 0 22px 18px;
    }
  }
</style>
