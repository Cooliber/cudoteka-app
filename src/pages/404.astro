---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title='Strona nie została znaleziona'
  description='Przepraszamy, ale ta strona nie istnieje. Wróć na stronę główną lub wybierz jedną z naszych sekcji.'
>
  <section class='section not-found-page'>
    <div class='wrap reveal-fade-up'>
      <div class='not-found-card'>
        <span class='eyebrow'>Błąd 404</span>
        <h1>Ups — tej strony nie ma w naszym katalogu</h1>
        <p>Najpewniej trafiłeś tutaj z nieaktualnego linku albo wpisano zły adres. Możesz wrócić na stronę główną albo przejrzeć naszą ofertę.</p>
        <div class='actions'>
          <a href='/' class='btn btn-primary'>Powrót na stronę główną</a>
          <a href='/oferta/' class='btn btn-ghost'>Zobacz ofertę</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found-page {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
    min-height: 80vh;
  }

  .not-found-card {
    max-width: 720px;
    margin: 0 auto;
    background: #fff;
    border-radius: var(--radius);
    padding: 48px;
    box-shadow: var(--shadow);
    text-align: center;
  }

  .not-found-card h1 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    margin: 18px 0 16px;
  }

  .not-found-card p {
    color: var(--ink-soft);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .actions {
    display: flex;
    justify-content: center;
    gap: 14px;
    flex-wrap: wrap;
  }

  @media (max-width: 680px) {
    .not-found-card {
      padding: 28px;
    }
  }
</style>
