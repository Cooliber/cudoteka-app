---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import aboutPhoto from '../assets/images/about/about.webp';

// Person schema for the founder — improves Subject Expertise / Trust signals
// in the SEO audit, and surfaces her as a clear entity to Google/AI systems.
// TODO(FOUNDER): expand credentials (education, certifications, years) — see
// docs/dane-dla-zalozycielki.md section 2.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Aleksandra Dąbrowska',
  givenName: 'Aleksandra',
  familyName: 'Dąbrowska',
  jobTitle: 'Założycielka Cudoteki, pedagog, logopeda',
  description: 'Pedagog, logopeda oraz certyfikowany trener Sensoplastyki® i Plastyki Ekspresywnej®. Od lat pracuje z dziećmi, tworząc przestrzeń, w której nauka spotyka się z radością tworzenia.',
  worksFor: { '@id': 'https://cudoteka.pl/#business' },
  knowsAbout: [
    'Sensoplastyka',
    'Plastyka ekspresywna',
    'Logopedia',
    'Pedagogika twórcza',
    'Edukacja alternatywna',
    'Animacje eventowe dla dzieci',
    'Eko-projekty edukacyjne',
  ],
  hasCredential: [
    // TODO(FOUNDER): uzupełnij o rzeczywiste certyfikaty (patrz docs/dane-dla-zalozycielki.md)
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'certification',
      name: 'Certyfikowany trener Sensoplastyki®',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'certification',
      name: 'Certyfikowany trener Plastyki Ekspresywnej®',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'degree',
      name: 'Pedagogika',
    },
    {
      '@type': 'EducationalOccupationalCredential',
      credentialCategory: 'degree',
      name: 'Logopedia',
    },
  ],
};
---

<BaseLayout
  title="O nas - Aleksandra Dąbrowska"
  description="Poznaj historię Cudoteki (dawniej E-CUD) i jej założycielki, Aleksandry Dąbrowskiej. Dowiedz się więcej o naszej misji i wartościach."
  schemas={[personSchema]}
>
  <section class="section about-page">
    <div class="wrap reveal-fade-up">
      <div class="about-grid">
        <!-- Text Column -->
        <div class="about-text">
          <span class="eyebrow">Nasza historia</span>
          <h1>Poznajmy się bliżej</h1>
          <p class="lead">Nazywam się <strong>Aleksandra Dąbrowska</strong> i jestem założycielką Cudoteki.</p>

          <p>
            Cudoteka (powstała z rebrandingu znanej i lubianej marki <strong>E-CUD - Centrum Edukacyjno-Eventowe</strong>) to urzeczywistnienie moich marzeń o stworzeniu miejsca, w którym nauka spotyka się z czystą radością tworzenia.
          </p>

          <p>
            Z wykształcenia jestem pedagogiem, logopedą oraz certyfikowanym trenerem Sensoplastyki® i Plastyki Ekspresywnej®. Od lat pracuję z dziećmi, obserwując jak niesamowity potencjał drzemie w każdym maluchu. Wierzę, że najlepszą formą nauki jest swobodne doświadczanie świata przez zmysły.
          </p>

          <div class="about-values">
            <h3>Nasze wartości:</h3>
            <ul class="values-list">
              <li>
                <strong>🛡️ Bezpieczeństwo:</strong> Używamy wyłącznie certyfikowanych i w 100% naturalnych (często spożywczych) składników.
              </li>
              <li>
                <strong>🎨 Swoboda twórcza:</strong> Nie oceniamy, nie narzucamy sztywnych szablonów. Liczy się proces i radość z działania.
              </li>
              <li>
                <strong>❤️ Pasja i serce:</strong> Każde zajęcia i animacje projektujemy tak, jakbyśmy przygotowywali je dla własnych dzieci.
              </li>
            </ul>
          </div>

          <div class="about-cta">
            <a href="/kontakt/" class="btn btn-primary">Porozmawiajmy o Twoim wydarzeniu</a>
          </div>
        </div>

        <!-- Image Column -->
        <div class="about-image-col">
          <div class="double-bezel-outer">
            <div class="img-inner double-bezel-inner">
              <Image formats={['avif', 'webp']} src={aboutPhoto} alt="Aleksandra Dąbrowska - Założycielka Cudoteki" width={500} height={560} widths={[400, 500, 700]} sizes="(max-width: 980px) 100vw, 500px" loading="lazy" decoding="async" class="about-photo" />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section credentials-section">
    <div class="wrap reveal-fade-up">
      <div class="sec-head">
        <span class="eyebrow">Kwalifikacje</span>
        <h2>Wykształcenie, certyfikaty i doświadczenie</h2>
        <p>Wszystko, co warto wiedzieć o mojej drodze do Cudoteki — żebyś wiedział/a, że Twoje dziecko jest w dobrych rękach.</p>
      </div>

      <div class="credentials-grid">
        <div class="credential-card">
          <div class="credential-icon">🎓</div>
          <h3>Wykształcenie</h3>
          <ul>
            <!-- TODO(FOUNDER): uzupełnij kierunek, uczelnię, rok ukończenia (docs/dane-dla-zalozycielki.md sekcja 2.1) -->
            <li><strong>Pedagogika</strong> — absolwentka</li>
            <li><strong>Logopedia</strong> — absolwentka</li>
          </ul>
        </div>

        <div class="credential-card">
          <div class="credential-icon">📜</div>
          <h3>Certyfikaty</h3>
          <ul>
            <!-- TODO(FOUNDER): rozszerz o rzeczywiste certyfikaty (max 5) — docs/dane-dla-zalozycielki.md sekcja 2.2 -->
            <li><strong>Certyfikowany trener Sensoplastyki®</strong></li>
            <li><strong>Certyfikowany trener Plastyki Ekspresywnej®</strong></li>
          </ul>
        </div>

        <div class="credential-card">
          <div class="credential-icon">⏳</div>
          <h3>Doświadczenie</h3>
          <!-- TODO(FOUNDER): podaj liczbę lat doświadczenia (docs/dane-dla-zalozycielki.md sekcja 2.3) -->
          <p class="credential-big">10+</p>
          <p class="credential-caption">lat pracy z dziećmi — w szkołach, przedszkolach i na eventach</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section mission-section">
    <div class="wrap reveal-fade-up">
      <div class="mission-card">
        <span class="eyebrow">Misja Cudoteki</span>
        <h2>Co jest dla nas najważniejsze</h2>
        <!-- TODO(FOUNDER): uzupełnij misję swoimi słowami (2-3 zdania) — docs/dane-dla-zalozycielki.md sekcja 2.4 -->
        <p>
          Wierzę, że najlepszą formą nauki jest swobodne doświadczanie świata przez zmysły. Cudoteka powstała, żeby dać dzieciom przestrzeń, w której mogą tworzyć bez oceny, popełniać błędy i odkrywać, że <em>samo tworzenie</em> jest cenniejsze niż efekt końcowy.
        </p>
        <p>
          Każde zajęcia i animacje projektuję tak, jakbym przygotowywała je dla własnych dzieci — z dbałością o bezpieczeństwo, rozwój i dobrą zabawę.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .credentials-section {
    background: var(--cream);
  }
  .credentials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 26px;
    max-width: 1080px;
    margin: 0 auto;
  }
  .credential-card {
    background: #fff;
    border-radius: var(--radius-sm);
    padding: 32px 28px;
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(62, 137, 176, 0.08);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1), box-shadow 0.3s;
  }
  .credential-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow);
  }
  .credential-icon {
    font-size: 2.2rem;
    margin-bottom: 12px;
  }
  .credential-card h3 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 1.25rem;
    margin-bottom: 16px;
    color: var(--ink);
  }
  .credential-card ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .credential-card li {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.5;
  }
  .credential-big {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 3.5rem;
    color: var(--blue-deep);
    line-height: 1;
    margin-bottom: 8px;
  }
  .credential-caption {
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.5;
  }

  .mission-section {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
  }
  .mission-card {
    max-width: 820px;
    margin: 0 auto;
    background: #fff;
    border-radius: var(--radius);
    padding: 48px 44px;
    box-shadow: var(--shadow);
    border: 1px solid rgba(62, 137, 176, 0.08);
  }
  .mission-card .eyebrow {
    margin-bottom: 8px;
  }
  .mission-card h2 {
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    margin-bottom: 24px;
  }
  .mission-card p {
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.75;
    margin-bottom: 16px;
  }
  .mission-card p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 980px) {
    .credentials-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
  }
  @media (max-width: 680px) {
    .mission-card {
      padding: 32px 26px;
    }
  }
</style>

<style>
  .about-page {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
    min-height: 80vh;
  }
  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .about-text h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    margin: 18px 0 20px;
  }
  .lead {
    font-size: 1.2rem;
    color: var(--blue-deep);
    font-weight: 700;
    margin-bottom: 20px;
  }
  .about-text p {
    color: var(--ink-soft);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 18px;
  }

  .about-values {
    margin-top: 30px;
    background: #fff;
    padding: 24px;
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-sm);
    border: 1px solid rgba(62, 137, 176, 0.08);
  }
  .about-values h3 {
    font-family: "Fraunces", serif;
    font-size: 1.3rem;
    margin-bottom: 16px;
  }
  .values-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .values-list li {
    font-size: 0.95rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .about-cta {
    margin-top: 36px;
  }

  /* Photo styling */
  .about-image-col {
    max-width: 500px;
    width: 100%;
    justify-self: center;
  }
  .img-inner {
    padding: 0 !important;
    overflow: hidden;
  }
  .about-photo {
    width: 100%;
    height: auto;
    object-fit: cover;
    display: block;
    border-radius: calc(2rem - 6px);
  }

  @media (max-width: 980px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .about-image-col {
      order: -1;
      max-width: 420px;
    }
  }
</style>
