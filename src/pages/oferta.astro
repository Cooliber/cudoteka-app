---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const categories = await getCollection('categories');
---

<BaseLayout
  title="Oferta warsztatów i animacji"
  description="Poznaj ofertę Cudoteki — sensoplastyka, warsztaty plastyczne, eksperymenty, strefa malucha i animacje na eventy w Warszawie i okolicach."
>
  <section class="section offer-intro">
    <div class="wrap reveal-fade-up">
      <div class="sec-head">
        <span class="eyebrow">Nasze atrakcje</span>
        <h1>Warsztaty i atrakcje na każdą okazję</h1>
        <p>Wybierz interesującą Cię kategorię i znajdź idealną rozrywkę dla swojej grupy lub na swoje wydarzenie.</p>
      </div>

      <div class="cat-grid">
        {categories.map(cat => (
          <div class="double-bezel-outer">
            <a href={`/oferta/${cat.data.slug}/`} class={`cat-card double-bezel-inner ${cat.data.color}`}>
              <div class="ic">{cat.data.icon}</div>
              <h3>{cat.data.title}</h3>
              <p>{cat.data.description}</p>
              <div class="btn-more">
                Zobacz warsztaty 
                <span class="arrow-wrapper">
                  <span class="arrow">→</span>
                </span>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .offer-intro {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
  }
  .sec-head {
    text-align: center;
    max-width: 46rem;
    margin: 0 auto 60px;
  }
  .sec-head h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    margin: 18px 0 16px;
  }
  .sec-head p {
    color: var(--ink-soft);
    font-size: 1.1rem;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
  }
  
  /* Double bezel layout tweaks */
  .double-bezel-outer {
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .double-bezel-outer:hover {
    transform: translateY(-8px);
  }
  
  .cat-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    justify-content: space-between;
    transition: all 0.3s ease;
  }
  
  .ic {
    width: 60px;
    height: 60px;
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    margin-bottom: 20px;
    transition: transform 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .double-bezel-outer:hover .ic {
    transform: scale(1.1) rotate(6deg);
  }
  
  /* Curated HSL Soft Pastels */
  .blue .ic { background: var(--blue-tint); }
  .mint .ic { background: var(--mint-tint); }
  .peach .ic { background: var(--peach-tint); }
  .gold .ic { background: #faf1dc; }
  .lilac .ic { background: #efe7f6; }
  
  .cat-card h3 {
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 12px;
  }
  .cat-card p {
    color: var(--ink-soft);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 24px;
    flex-grow: 1;
  }
  
  /* Nested Button/Arrow effect */
  .btn-more {
    font-weight: 800;
    color: var(--blue-deep);
    font-size: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: color 0.3s;
  }
  .arrow-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    background-color: var(--blue-tint);
    border-radius: 50%;
    transition: background-color 0.3s, transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .arrow {
    font-size: 1rem;
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .double-bezel-outer:hover .btn-more {
    color: var(--blue);
  }
  .double-bezel-outer:hover .arrow-wrapper {
    background-color: var(--blue-soft);
    transform: scale(1.1);
  }
  .double-bezel-outer:hover .arrow {
    transform: translateX(3px);
  }
  
  @media (max-width: 980px) {
    .cat-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }
  @media (max-width: 680px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
    .sec-head {
      margin-bottom: 40px;
    }
  }
</style>
