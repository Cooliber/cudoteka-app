---
import BaseLayout from '../layouts/BaseLayout.astro';
import WorkshopList from '../components/workshops/WorkshopList.astro';
---

<BaseLayout
  title="Kreatywne warsztaty dla dzieci i dorosłych"
  description="Przeglądaj pełną ofertę ponad 20 rodzajów warsztatów rozwojowych i artystycznych, sensoplastyki, eksperymentów i animacji w Warszawie i okolicach."
>
  <section class="section workshops-intro">
    <div class="wrap reveal-fade-up">
      <div class="sec-head">
        <span class="eyebrow">Nasze zajęcia</span>
        <h1>Odkryj kreatywny świat Cudoteki</h1>
        <p>Wszystkie nasze warsztaty prowadzimy z pasją, dbając o pełne bezpieczeństwo uczestników. Wybierz zajęcia i sprawdź szczegóły.</p>
      </div>

      <!-- Workshop List Component with Client Filter -->
      <WorkshopList />
    </div>
  </section>
</BaseLayout>

<style>
  .workshops-intro {
    background: linear-gradient(180deg, var(--cream), var(--cream-2));
    min-height: 80vh;
  }
  .sec-head {
    text-align: center;
    max-width: 46rem;
    margin: 0 auto 54px;
  }
  .sec-head h1 {
    font-size: clamp(2.5rem, 4.5vw, 3.5rem);
    margin: 18px 0 16px;
  }
  .sec-head p {
    color: var(--ink-soft);
    font-size: 1.1rem;
  }
  @media (max-width: 680px) {
    .sec-head {
      margin-bottom: 34px;
    }
  }
</style>
