---
const navLinks = [
  { href: '/o-nas/', label: 'O nas' },
  { href: '/oferta/', label: 'Oferta' },
  { href: '/warsztaty/', label: 'Warsztaty' },
  { href: '/materialy/', label: 'Materiały' },
  { href: '/szkolenia/', label: 'Szkolenia' },
  { href: '/blog/', label: 'Blog' },
  { href: '/galeria/', label: 'Galeria' },
  { href: '/opinie/', label: 'Opinie' },
  { href: '/kontakt/', label: 'Kontakt' },
];
---

<header class="header-container">
  <div class="wrap header-pill">
    <a href="/" class="logo" aria-label="Cudoteka">
      <svg width="30" height="30" viewBox="0 0 32 32" fill="none" class="logo-svg">
        <path d="M16 4c1.6 2.2 1.6 4.6 0 6.8C14.4 8.6 14.4 6.2 16 4Z" fill="#3E89B0"/>
        <path d="M28 16c-2.2 1.6-4.6 1.6-6.8 0 2.2-1.6 4.6-1.6 6.8 0Z" fill="#3E89B0"/>
        <path d="M16 28c-1.6-2.2-1.6-4.6 0-6.8 1.6 2.2 1.6 4.6 0 6.8Z" fill="#3E89B0"/>
        <path d="M4 16c2.2-1.6 4.6-1.6 6.8 0-2.2 1.6-4.6 1.6-6.8 0Z" fill="#3E89B0"/>
        <path d="M24.5 7.5c-.4 2.6-2 4.4-4.6 5 0.4-2.6 2-4.4 4.6-5Z" fill="#EF9E80"/>
        <path d="M7.5 24.5c.4-2.6 2-4.4 4.6-5-.4 2.6-2 4.4-4.6 5Z" fill="#EF9E80"/>
        <path d="M24.5 24.5c-2.6-.4-4.4-2-5-4.6 2.6.4 4.4 2 5 4.6Z" fill="#7FC4A6"/>
        <path d="M7.5 7.5c2.6.4 4.4 2 5 4.6-2.6-.4-4.4-2-5-4.6Z" fill="#7FC4A6"/>
        <circle cx="16" cy="16" r="3" fill="#E7B85C"/>
      </svg>
      <span class="logo-text">Cudoteka</span>
    </a>
    <nav class="nav-links" aria-label="Nawigacja główna">
      {navLinks.map(link => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
    <div class="nav-cta">
      <a href="tel:607370777" class="phone-link">607 370 777</a>
      <a href="/kontakt/" class="btn btn-primary">Zarezerwuj termin</a>
    </div>
    <button class="burger" id="burger-button" aria-label="Otwórz menu" aria-expanded="false" aria-controls="mobile-menu-overlay">
      <span class="line-1"></span>
      <span class="line-2"></span>
      <span class="line-3"></span>
    </button>
  </div>
</header>

<!-- Mobile full-screen overlay menu -->
<div class="mobile-overlay" id="mobile-menu-overlay">
  <div class="mobile-overlay-bg"></div>
  <nav class="mobile-nav-links">
    {navLinks.map((link, index) => (
      <a href={link.href} style={`--stagger-index: ${index};`}>{link.label}</a>
    ))}
    <div class="mobile-nav-cta" style={`--stagger-index: ${navLinks.length};`}>
      <a href="tel:607370777" class="btn btn-ghost">Zadzwoń: 607 370 777</a>
      <a href="/kontakt/" class="btn btn-primary">Zarezerwuj termin</a>
    </div>
  </nav>
</div>

<style>
  .header-container {
    position: sticky;
    top: 14px;
    left: 0;
    right: 0;
    z-index: 100;
    pointer-events: none;
    margin-bottom: 24px;
  }
  .header-pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 24px;
    background: rgba(251, 247, 241, 0.75);
    backdrop-filter: blur(16px) saturate(120%);
    -webkit-backdrop-filter: blur(16px) saturate(120%);
    border: 1px solid rgba(62, 137, 176, 0.15);
    border-radius: 999px;
    box-shadow: 0 10px 30px -10px rgba(41, 106, 142, 0.15);
    transition: all 0.3s ease;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-family: "Fraunces", Georgia, serif;
    font-weight: 700;
    font-size: 1.4rem;
    color: var(--blue-deep);
    transition: transform 0.2s ease;
  }
  .logo:hover {
    transform: scale(1.02);
  }
  .logo-svg {
    flex: none;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 24px;
    font-weight: 700;
  }
  .nav-links a {
    color: var(--ink-soft);
    font-size: 0.95rem;
    position: relative;
    padding: 6px 0;
    transition: color 0.2s;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--blue);
    transition: width 0.3s ease;
  }
  .nav-links a:hover {
    color: var(--blue-deep);
  }
  .nav-links a:hover::after {
    width: 100%;
  }
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 18px;
  }
  .phone-link {
    font-weight: 800;
    color: var(--blue-deep);
    font-size: 0.95rem;
    transition: color 0.2s;
  }
  .phone-link:hover {
    color: var(--blue);
  }
  .nav-cta .btn {
    padding: 10px 22px;
    font-size: 0.9rem;
  }

  /* Hamburger Menu */
  .burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    width: 40px;
    height: 40px;
    z-index: 110;
    border-radius: 50%;
    transition: background-color 0.2s;
  }
  .burger:hover {
    background-color: rgba(62, 137, 176, 0.1);
  }
  .burger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--blue-deep);
    border-radius: 2px;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1), opacity 0.3s, background-color 0.3s;
  }

  /* Hamburger Active/Morph state */
  .burger.open .line-1 {
    transform: translateY(8px) rotate(45deg);
  }
  .burger.open .line-2 {
    opacity: 0;
    transform: scaleX(0);
  }
  .burger.open .line-3 {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Mobile Overlay */
  .mobile-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100dvh;
    z-index: 90;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    visibility: hidden;
    transition: visibility 0.5s;
  }
  .mobile-overlay.open {
    pointer-events: auto;
    visibility: visible;
  }
  .mobile-overlay-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(251, 247, 241, 0.9);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    opacity: 0;
    transition: opacity 0.5s cubic-bezier(0.32, 0.72, 0, 1);
  }
  .mobile-overlay.open .mobile-overlay-bg {
    opacity: 1;
  }
  .mobile-nav-links {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    text-align: center;
    width: 100%;
    padding: 0 40px;
  }
  .mobile-nav-links a {
    font-family: "Fraunces", Georgia, serif;
    font-size: 2rem;
    font-weight: 600;
    color: var(--ink);
    opacity: 0;
    transform: translateY(40px);
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
    transition-delay: calc(var(--stagger-index) * 0.05s);
  }
  .mobile-overlay.open .mobile-nav-links a {
    opacity: 1;
    transform: translateY(0);
  }
  .mobile-nav-links a:hover {
    color: var(--blue-deep);
  }
  .mobile-nav-cta {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 100%;
    max-width: 280px;
    opacity: 0;
    transform: translateY(40px);
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.6s ease;
    transition-delay: calc(var(--stagger-index) * 0.05s);
  }
  .mobile-overlay.open .mobile-nav-cta {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 980px) {
    .nav-links, .nav-cta {
      display: none;
    }
    .burger {
      display: flex;
    }
    .header-pill {
      border-radius: 28px;
      padding: 10px 20px;
    }
  }
</style>

<script>
  // Script for Burger menu interaction
  document.addEventListener('DOMContentLoaded', () => {
    const burger = document.getElementById('burger-button');
    const overlay = document.getElementById('mobile-menu-overlay');
    const links = document.querySelectorAll('.mobile-nav-links a');

    if (burger && overlay) {
      const toggleMenu = () => {
        const isOpen = burger.classList.toggle('open');
        overlay.classList.toggle('open');
        burger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');

        // Prevent body scroll when menu is open
        document.body.style.overflow = isOpen ? 'hidden' : '';
      };

      burger.addEventListener('click', toggleMenu);

      links.forEach(link => {
        link.addEventListener('click', () => {
          burger.classList.remove('open');
          overlay.classList.remove('open');
          burger.setAttribute('aria-expanded', 'false');
          document.body.style.overflow = '';
        });
      });
    }
  });
</script>
