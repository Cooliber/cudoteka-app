---
import '../styles/global.css';
import '../styles/utilities.css';
import { seo, localBusinessSchema } from '../lib/seo';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  type?: string;
  schemas?: Record<string, unknown>[];
}

const { title, description, image, canonical, type, schemas = [] } = Astro.props;

// Always emit an absolute canonical URL derived from the current route unless one is passed explicitly.
const canonicalURL = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
const seoData = seo({ title, description, image, canonical: canonicalURL, type });
const schema = localBusinessSchema();
---

<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <title>{seoData.title}</title>
  {seoData.meta.map(m => {
    if ('name' in m) {
      return <meta name={m.name} content={m.content} />;
    } else {
      return <meta property={m.property} content={m.content} />;
    }
  })}
  <link rel="canonical" href={canonicalURL} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!--
    Non-blocking font load: preload the CSS, then swap media to 'all' once it arrives.
    Falls back to a blocking <link> for users with JavaScript disabled.
  -->
  <link
    rel="preload"
    as="style"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Nunito+Sans:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap"
  />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Nunito+Sans:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,600;0,9..144,700;1,9..144,500&family=Nunito+Sans:ital,wght@0,400;0,600;0,700;0,800;1,400&display=swap"
    />
  </noscript>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  {schemas.map((s) => (
    <script type="application/ld+json" set:html={JSON.stringify(s)} />
  ))}
</head>
<body>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />

  <script>
    // Premium reveal on scroll logic using IntersectionObserver
    document.addEventListener('DOMContentLoaded', () => {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('active');
          }
        });
      }, {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      });

      document.querySelectorAll('.reveal-fade-up').forEach(el => {
        observer.observe(el);
      });
    });
  </script>
</body>
</html>
